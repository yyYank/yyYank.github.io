---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeadacheDiary from '../components/diary/HeadacheDiary.tsx';
---

<BaseLayout title="Diary" description="頭痛記録">
  <div class="container mx-auto px-4 py-8 max-w-4xl">
    <h1 class="text-3xl font-bold text-white mb-2">Diary</h1>
    <p class="text-gray-400 mb-8">頭痛の症状記録</p>
    <HeadacheDiary client:load />
  </div>
</BaseLayout>
