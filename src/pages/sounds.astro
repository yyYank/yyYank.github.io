---
import BaseLayout from '../layouts/BaseLayout.astro';
import AudioConverter from '../components/sounds/AudioConverter.tsx';
import AudioMerger from '../components/sounds/AudioMerger.tsx';
import AudioTrimmer from '../components/sounds/AudioTrimmer.tsx';
---

<BaseLayout title="Audio Tool" description="音声変換・連結・トリミングツール（ブラウザ内処理）">
  <div class="container mx-auto px-4 py-8 max-w-4xl">
    <h1 class="text-3xl font-bold text-white mb-2">Audio Tool</h1>
    <p class="text-gray-400 mb-8">音声変換・連結・トリミングツール — ブラウザ内で処理（サーバー不要）</p>
    <div class="grid md:grid-cols-2 gap-6">
      <AudioConverter client:load />
      <AudioMerger client:load />
    </div>
    <div class="mt-6">
      <AudioTrimmer client:load />
    </div>
    <p class="mt-6 text-xs text-gray-600">
      処理はすべてブラウザ内で行われます。ファイルはサーバーに送信されません。<br />
      初回ロード時に ffmpeg.wasm（約30MB）をダウンロードします。
    </p>
  </div>
</BaseLayout>
