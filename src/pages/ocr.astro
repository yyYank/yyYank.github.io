---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="OCR — 付箋・メモOCR" description="付箋・メモ・ホワイトボードの画像からテキストを抽出">
  <style>
    :root {
      --snap-bg: #0f0e0c;
      --snap-surface: #1a1916;
      --snap-border: #2e2c28;
      --snap-accent: #f5c842;
      --snap-accent2: #e87040;
      --snap-text: #f0ede6;
      --snap-muted: #7a786f;
      --snap-green: #5ec87a;
      --snap-radius: 12px;
    }

    .snap-wrap {
      background: var(--snap-bg);
      color: var(--snap-text);
      font-family: 'Zen Kaku Gothic New', 'Noto Sans JP', sans-serif;
      min-height: calc(100vh - 64px);
      display: flex;
      flex-direction: column;
    }

    /* PROGRESS BAR */
    .progress-wrap {
      background: var(--snap-surface);
      border: 1px solid var(--snap-border);
      border-radius: 6px;
      overflow: hidden;
      height: 6px;
      display: none;
    }
    .progress-wrap.show { display: block; }
    .progress-bar {
      height: 100%;
      background: var(--snap-accent);
      width: 0%;
      transition: width 0.3s ease;
    }

    /* MAIN LAYOUT */
    .snap-main {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 0;
    }

    @media (max-width: 768px) {
      .snap-main { grid-template-columns: 1fr; }
      .panel-right { border-left: none; border-top: 1px solid var(--snap-border); }
    }

    /* PANELS */
    .panel-left {
      border-right: 1px solid var(--snap-border);
      display: flex;
      flex-direction: column;
      padding: 28px 32px;
      gap: 20px;
    }
    .panel-right {
      display: flex;
      flex-direction: column;
      padding: 28px 32px;
      gap: 16px;
    }

    .step-label {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.1em;
      color: var(--snap-accent);
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    /* DROP ZONE */
    .drop-zone {
      border: 2px dashed var(--snap-border);
      border-radius: var(--snap-radius);
      padding: 40px 24px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      position: relative;
      background: var(--snap-surface);
    }
    .drop-zone:hover, .drop-zone.drag-over {
      border-color: var(--snap-accent);
      background: #1c1a0e;
    }
    .drop-zone input[type=file] {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
      width: 100%;
      height: 100%;
    }
    .drop-icon { font-size: 40px; line-height: 1; margin-bottom: 12px; }
    .drop-title { font-size: 15px; font-weight: 700; margin-bottom: 4px; }
    .drop-sub { font-size: 12px; color: var(--snap-muted); }
    .file-name { font-size: 12px; color: var(--snap-accent); margin-top: 8px; }

    /* PREVIEW */
    .preview-area {
      display: none;
      position: relative;
      border-radius: var(--snap-radius);
      overflow: hidden;
      background: var(--snap-surface);
      min-height: 140px;
      align-items: center;
      justify-content: center;
    }
    .preview-area.show { display: flex; }
    .preview-area img {
      max-width: 100%;
      max-height: 280px;
      object-fit: contain;
      border-radius: var(--snap-radius);
    }
    .preview-clear {
      position: absolute;
      top: 8px; right: 8px;
      background: rgba(0,0,0,0.7);
      border: none;
      color: var(--snap-text);
      width: 26px; height: 26px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 13px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .preview-toolbar {
      display: none;
      gap: 8px;
      margin-top: 10px;
      flex-wrap: wrap;
    }
    .preview-toolbar.show { display: flex; }
    .secondary-btn {
      padding: 9px 14px;
      background: var(--snap-surface);
      border: 1px solid var(--snap-border);
      border-radius: 8px;
      color: var(--snap-text);
      font-family: inherit;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.15s;
    }
    .secondary-btn:hover:not(:disabled) {
      border-color: var(--snap-accent);
      color: var(--snap-accent);
    }
    .secondary-btn:disabled {
      color: var(--snap-muted);
      cursor: not-allowed;
      opacity: 0.6;
    }

    /* CAMERA */
    .camera-btn {
      width: 100%;
      padding: 10px;
      background: var(--snap-surface);
      border: 1px solid var(--snap-border);
      border-radius: 8px;
      color: var(--snap-muted);
      font-family: inherit;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.15s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .camera-btn:hover { border-color: var(--snap-accent); color: var(--snap-text); }

    /* FORMAT BUTTONS */
    .format-options {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .fmt-btn {
      padding: 7px 16px;
      border-radius: 6px;
      border: 1px solid var(--snap-border);
      background: var(--snap-surface);
      color: var(--snap-muted);
      font-family: inherit;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.15s;
    }
    .fmt-btn:hover { border-color: var(--snap-accent); color: var(--snap-text); }
    .fmt-btn.active {
      background: var(--snap-accent);
      border-color: var(--snap-accent);
      color: #0f0e0c;
    }

    /* EXTRACT BUTTON */
    .extract-btn {
      width: 100%;
      padding: 14px;
      background: var(--snap-accent);
      color: #0f0e0c;
      border: none;
      border-radius: var(--snap-radius);
      font-family: inherit;
      font-size: 16px;
      font-weight: 900;
      cursor: pointer;
      transition: all 0.15s;
      letter-spacing: 0.03em;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .extract-btn:hover { background: #f0bc28; transform: translateY(-1px); }
    .extract-btn:disabled {
      background: var(--snap-border);
      color: var(--snap-muted);
      cursor: not-allowed;
      transform: none;
    }

    /* OUTPUT PANEL */
    .output-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
    }
    .output-actions {
      display: flex;
      gap: 8px;
    }
    .action-btn {
      padding: 7px 14px;
      border-radius: 6px;
      border: 1px solid var(--snap-border);
      background: var(--snap-surface);
      color: var(--snap-muted);
      font-family: inherit;
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.15s;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .action-btn:hover { border-color: var(--snap-accent); color: var(--snap-text); }
    .action-btn.copied { border-color: var(--snap-green); color: var(--snap-green); }

    .output-box {
      flex: 1;
      background: var(--snap-surface);
      border: 1px solid var(--snap-border);
      border-radius: var(--snap-radius);
      padding: 20px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      line-height: 1.7;
      color: var(--snap-text);
      resize: none;
      outline: none;
      min-height: 320px;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .output-box:focus { border-color: var(--snap-border); }

    /* EMPTY STATE */
    .empty-state {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
      color: var(--snap-muted);
      text-align: center;
      background: var(--snap-surface);
      border: 1px solid var(--snap-border);
      border-radius: var(--snap-radius);
      min-height: 320px;
    }
    .empty-icon { font-size: 36px; opacity: 0.5; }
    .empty-text { font-size: 14px; line-height: 1.7; }

    /* API KEY HINT */
    .apikey-hint {
      font-size: 11px;
      color: var(--snap-muted);
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }
    .apikey-hint input {
      flex: 1;
      min-width: 140px;
      background: var(--snap-surface);
      border: 1px solid var(--snap-border);
      border-radius: 4px;
      padding: 4px 8px;
      color: var(--snap-text);
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      outline: none;
    }
    .apikey-hint input:focus { border-color: var(--snap-accent); }
    .apikey-hint a { color: var(--snap-accent); text-decoration: none; }
    .apikey-hint a:hover { text-decoration: underline; }

    /* STATUS */
    .status-bar {
      font-size: 12px;
      color: var(--snap-muted);
      min-height: 18px;
    }
    .status-bar.loading { color: var(--snap-accent); }
    .status-bar.error { color: var(--snap-accent2); }
    .status-bar.success { color: var(--snap-green); }

    /* SPINNER */
    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner {
      display: inline-block;
      width: 14px; height: 14px;
      border: 2px solid #3a3210;
      border-top-color: var(--snap-accent);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      vertical-align: middle;
      margin-right: 6px;
    }

    /* CROP MODAL */
    .crop-modal {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 110;
      background: rgba(0, 0, 0, 0.88);
      padding: 24px;
      align-items: center;
      justify-content: center;
    }
    .crop-modal.show { display: flex; }
    .crop-panel {
      width: min(960px, 100%);
      max-height: calc(100vh - 48px);
      background: var(--snap-surface);
      border: 1px solid var(--snap-border);
      border-radius: 16px;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .crop-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .crop-title {
      font-size: 16px;
      font-weight: 900;
      color: var(--snap-text);
    }
    .crop-subtitle {
      font-size: 12px;
      color: var(--snap-muted);
    }
    .crop-stage {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 320px;
      max-height: 65vh;
      overflow: auto;
      background:
        linear-gradient(45deg, #171511 25%, transparent 25%) -12px 0/24px 24px,
        linear-gradient(-45deg, #171511 25%, transparent 25%) -12px 0/24px 24px,
        linear-gradient(45deg, transparent 75%, #171511 75%) -12px 0/24px 24px,
        linear-gradient(-45deg, transparent 75%, #171511 75%) -12px 0/24px 24px;
      border-radius: 12px;
      border: 1px solid var(--snap-border);
      user-select: none;
      touch-action: none;
    }
    .crop-image-wrap {
      position: relative;
      line-height: 0;
      max-width: 100%;
    }
    .crop-image {
      display: block;
      max-width: 100%;
      max-height: 60vh;
      border-radius: 8px;
    }
    .crop-selection {
      position: absolute;
      border: 2px solid var(--snap-accent);
      background: rgba(245, 200, 66, 0.12);
      box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.45);
      pointer-events: none;
      display: none;
    }
    .crop-selection.show { display: block; }
    .crop-actions {
      display: flex;
      justify-content: flex-end;
      gap: 8px;
      flex-wrap: wrap;
    }

    @media (max-width: 768px) {
      .crop-modal { padding: 12px; }
      .crop-panel {
        padding: 14px;
        max-height: calc(100vh - 24px);
      }
      .crop-stage {
        min-height: 240px;
        max-height: 55vh;
      }
    }
  </style>

  <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;700;900&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">

  <div class="snap-wrap">
    <div class="snap-main">
      <!-- LEFT PANEL -->
      <div class="panel-left">
        <!-- STEP 1 -->
        <div>
          <div class="step-label">① 画像をアップロード</div>

          <div class="drop-zone" id="dropZone">
            <input type="file" id="fileInput" accept="image/*" />
            <div class="drop-icon">📸</div>
            <div class="drop-title">ここにドロップ or クリック</div>
            <div class="drop-sub">付箋・メモ・ホワイトボードなど</div>
            <div class="drop-sub">JPG, PNG, WEBP, HEIC 対応</div>
            <div class="file-name" id="fileName">選択されていません</div>
          </div>

          <div class="preview-area" id="previewArea">
            <img id="previewImg" src="" alt="preview" />
            <button class="preview-clear" id="clearBtn" title="クリア">✕</button>
          </div>
          <div class="preview-toolbar" id="previewToolbar">
            <button class="secondary-btn" id="cropBtn" type="button">✂️ トリミング</button>
            <button class="secondary-btn" id="restoreBtn" type="button" disabled>元画像に戻す</button>
          </div>

          <button class="camera-btn" id="cameraBtn" style="margin-top: 10px;">
            📷 カメラで撮影
          </button>
          <input type="file" id="cameraInput" accept="image/*" capture="environment" style="display:none" />
        </div>

        <!-- STEP 2 -->
        <div>
          <div class="step-label">② オプション</div>
          <label style="display:flex; align-items:center; gap:8px; font-size:13px; color:var(--snap-muted); cursor:pointer;">
            <input type="checkbox" id="isTable" style="accent-color:var(--snap-accent); width:14px; height:14px;" />
            テーブル検出（レシート・表など）
          </label>
        </div>

        <!-- STEP 3 -->
        <div>
          <div class="step-label">③ 出力フォーマット</div>
          <div class="format-options" id="formatOptions">
            <button class="fmt-btn active" data-fmt="markdown">Markdown</button>
            <button class="fmt-btn" data-fmt="todo">TODO</button>
            <button class="fmt-btn" data-fmt="csv">CSV</button>
            <button class="fmt-btn" data-fmt="tsv">TSV</button>
            <button class="fmt-btn" data-fmt="plain">プレーンテキスト</button>
            <button class="fmt-btn" data-fmt="bullet">箇条書き</button>
          </div>
        </div>

        <!-- EXTRACT -->
        <button class="extract-btn" id="extractBtn" disabled>
          ⚡ ④ テキスト抽出
        </button>

        <div class="progress-wrap" id="progressWrap">
          <div class="progress-bar" id="progressBar"></div>
        </div>

        <div class="status-bar" id="statusBar"></div>

        <div class="apikey-hint">
          <span>APIキー:</span>
          <input type="text" id="ocrApiKey" placeholder="デフォルトキー使用中" />
          <a href="https://ocr.space/ocrapi/freekey" target="_blank" rel="noopener">無料キー取得</a>
        </div>
      </div>

      <!-- RIGHT PANEL -->
      <div class="panel-right">
        <div class="output-header">
          <div class="step-label">③ 抽出結果</div>
          <div class="output-actions">
            <button class="action-btn" id="copyBtn">📋 コピー</button>
            <button class="action-btn" id="downloadBtn">💾 ダウンロード</button>
          </div>
        </div>

        <div class="empty-state" id="emptyState">
          <div class="empty-icon">✨</div>
          <div class="empty-text">
            画像をアップロードして<br>「テキスト抽出」を押すと<br>ここに結果が表示されます
          </div>
        </div>

        <textarea class="output-box" id="outputBox" style="display:none" placeholder="抽出結果がここに表示されます..."></textarea>
      </div>
    </div>
  </div>

  <!-- CAMERA MODAL -->
  <div id="cameraModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:100; align-items:center; justify-content:center; flex-direction:column; gap:16px;">
    <video id="cameraVideo" autoplay playsinline style="max-width:90vw; max-height:60vh; border-radius:12px; border:2px solid #f5c842;"></video>
    <div style="display:flex; gap:12px;">
      <button id="captureBtn" style="padding:12px 28px; background:#f5c842; color:#0f0e0c; border:none; border-radius:8px; font-size:15px; font-weight:900; cursor:pointer;">📸 撮影</button>
      <button id="closeCameraBtn" style="padding:12px 28px; background:#2e2c28; color:#f0ede6; border:1px solid #2e2c28; border-radius:8px; font-size:15px; cursor:pointer;">キャンセル</button>
    </div>
    <canvas id="captureCanvas" style="display:none;"></canvas>
  </div>

  <div class="crop-modal" id="cropModal">
    <div class="crop-panel">
      <div class="crop-header">
        <div>
          <div class="crop-title">画像をトリミング</div>
          <div class="crop-subtitle">必要な範囲だけドラッグして選択すると OCR のノイズを減らせます</div>
        </div>
      </div>
      <div class="crop-stage" id="cropStage">
        <div class="crop-image-wrap" id="cropImageWrap">
          <img class="crop-image" id="cropImage" src="" alt="crop target" />
          <div class="crop-selection" id="cropSelection"></div>
        </div>
      </div>
      <div class="crop-actions">
        <button class="secondary-btn" id="cropResetBtn" type="button">選択をリセット</button>
        <button class="secondary-btn" id="cropCancelBtn" type="button">キャンセル</button>
        <button class="extract-btn" id="cropApplyBtn" type="button" disabled style="width:auto; padding:10px 18px;">この範囲で切り抜く</button>
      </div>
    </div>
  </div>

  <script>
    (() => {
      const OCR_SPACE_DEMO_KEY = 'K88888888888888';

      let imageFile = null;
      let originalImageFile = null;
      let selectedFormat = 'markdown';
      let cameraStream = null;
      let rawOcrText = null;
      let cropRect = null;
      let cropPointerId = null;
      let cropStartPoint = null;

      const dropZone = document.getElementById('dropZone');
      const fileInput = document.getElementById('fileInput');
      const fileName = document.getElementById('fileName');
      const previewArea = document.getElementById('previewArea');
      const previewImg = document.getElementById('previewImg');
      const previewToolbar = document.getElementById('previewToolbar');
      const clearBtn = document.getElementById('clearBtn');
      const cropBtn = document.getElementById('cropBtn');
      const restoreBtn = document.getElementById('restoreBtn');
      const cameraBtn = document.getElementById('cameraBtn');
      const cameraInput = document.getElementById('cameraInput');
      const formatOptions = document.getElementById('formatOptions');
      const ocrApiKeyEl = document.getElementById('ocrApiKey');
      const isTableEl = document.getElementById('isTable');
      const savedKey = localStorage.getItem('snaptext_ocrkey');
      if (savedKey) ocrApiKeyEl.value = savedKey;
      ocrApiKeyEl.addEventListener('input', () => {
        const v = ocrApiKeyEl.value.trim();
        v ? localStorage.setItem('snaptext_ocrkey', v) : localStorage.removeItem('snaptext_ocrkey');
      });
      const extractBtn = document.getElementById('extractBtn');
      const progressWrap = document.getElementById('progressWrap');
      const progressBar = document.getElementById('progressBar');
      const statusBar = document.getElementById('statusBar');
      const emptyState = document.getElementById('emptyState');
      const outputBox = document.getElementById('outputBox');
      const copyBtn = document.getElementById('copyBtn');
      const downloadBtn = document.getElementById('downloadBtn');
      const cameraModal = document.getElementById('cameraModal');
      const cameraVideo = document.getElementById('cameraVideo');
      const captureBtn = document.getElementById('captureBtn');
      const closeCameraBtn = document.getElementById('closeCameraBtn');
      const captureCanvas = document.getElementById('captureCanvas');
      const cropModal = document.getElementById('cropModal');
      const cropStage = document.getElementById('cropStage');
      const cropImageWrap = document.getElementById('cropImageWrap');
      const cropImage = document.getElementById('cropImage');
      const cropSelection = document.getElementById('cropSelection');
      const cropResetBtn = document.getElementById('cropResetBtn');
      const cropCancelBtn = document.getElementById('cropCancelBtn');
      const cropApplyBtn = document.getElementById('cropApplyBtn');

      // Format selection — re-convert if result already exists
      formatOptions.addEventListener('click', (e) => {
        const btn = e.target.closest('.fmt-btn');
        if (!btn) return;
        formatOptions.querySelectorAll('.fmt-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        selectedFormat = btn.dataset.fmt;
        if (rawOcrText !== null) {
          outputBox.value = convertFormat(rawOcrText, selectedFormat);
        }
      });

      // File load helper
      function resetOutput() {
        rawOcrText = null;
        progressWrap.classList.remove('show');
        progressBar.style.width = '0%';
        setStatus('', '');
        emptyState.style.display = '';
        outputBox.style.display = 'none';
        outputBox.value = '';
      }

      function updateRestoreButton() {
        restoreBtn.disabled = !originalImageFile || !imageFile || originalImageFile === imageFile;
      }

      function loadFile(file, options = {}) {
        if (!file || !file.type.startsWith('image/')) return;
        if (!options.preserveOriginal) originalImageFile = file;
        imageFile = file;
        fileName.textContent = file.name;
        resetOutput();
        const reader = new FileReader();
        reader.onload = (e) => {
          previewImg.src = e.target.result;
          dropZone.style.display = 'none';
          previewArea.classList.add('show');
          previewToolbar.classList.add('show');
          extractBtn.disabled = false;
          updateRestoreButton();
        };
        reader.readAsDataURL(file);
      }

      // Drag & Drop
      dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag-over'); });
      dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
      dropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
        loadFile(e.dataTransfer.files[0]);
      });
      fileInput.addEventListener('change', () => loadFile(fileInput.files[0]));

      // Clipboard paste
      document.addEventListener('paste', (e) => {
        const item = [...e.clipboardData.items].find(i => i.type.startsWith('image/'));
        if (item) loadFile(item.getAsFile());
      });

      // Clear
      clearBtn.addEventListener('click', () => {
        imageFile = null;
        originalImageFile = null;
        fileName.textContent = '選択されていません';
        previewImg.src = '';
        previewArea.classList.remove('show');
        previewToolbar.classList.remove('show');
        dropZone.style.display = '';
        fileInput.value = '';
        extractBtn.disabled = true;
        resetOutput();
        updateRestoreButton();
      });

      // Camera
      cameraBtn.addEventListener('click', async () => {
        if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
          try {
            cameraStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
            cameraVideo.srcObject = cameraStream;
            cameraModal.style.display = 'flex';
            return;
          } catch (_) { /* fallback */ }
        }
        cameraInput.click();
      });
      cameraInput.addEventListener('change', () => loadFile(cameraInput.files[0]));

      captureBtn.addEventListener('click', () => {
        captureCanvas.width = cameraVideo.videoWidth;
        captureCanvas.height = cameraVideo.videoHeight;
        captureCanvas.getContext('2d').drawImage(cameraVideo, 0, 0);
        captureCanvas.toBlob((blob) => {
          loadFile(new File([blob], 'camera.jpg', { type: 'image/jpeg' }));
          closeCamera();
        }, 'image/jpeg', 0.92);
      });

      closeCameraBtn.addEventListener('click', closeCamera);
      function closeCamera() {
        if (cameraStream) { cameraStream.getTracks().forEach(t => t.stop()); cameraStream = null; }
        cameraModal.style.display = 'none';
      }

      function resetCropSelection() {
        cropRect = null;
        cropSelection.classList.remove('show');
        cropSelection.style.left = '0px';
        cropSelection.style.top = '0px';
        cropSelection.style.width = '0px';
        cropSelection.style.height = '0px';
        cropApplyBtn.disabled = true;
      }

      function closeCropModal() {
        cropModal.classList.remove('show');
        document.body.style.overflow = '';
        if (cropPointerId !== null) {
          cropImage.releasePointerCapture(cropPointerId);
          cropPointerId = null;
        }
        cropStartPoint = null;
        resetCropSelection();
      }

      function openCropModal() {
        if (!imageFile) return;
        cropImage.src = previewImg.src;
        cropModal.classList.add('show');
        document.body.style.overflow = 'hidden';
        resetCropSelection();
      }

      function eventToImagePoint(event) {
        const rect = cropImage.getBoundingClientRect();
        const x = Math.min(Math.max(event.clientX - rect.left, 0), rect.width);
        const y = Math.min(Math.max(event.clientY - rect.top, 0), rect.height);
        return { x, y, width: rect.width, height: rect.height };
      }

      function renderCropSelection() {
        if (!cropRect) return;
        cropSelection.classList.add('show');
        cropSelection.style.left = `${cropRect.x}px`;
        cropSelection.style.top = `${cropRect.y}px`;
        cropSelection.style.width = `${cropRect.width}px`;
        cropSelection.style.height = `${cropRect.height}px`;
        cropApplyBtn.disabled = cropRect.width < 8 || cropRect.height < 8;
      }

      cropBtn.addEventListener('click', openCropModal);
      restoreBtn.addEventListener('click', () => {
        if (!originalImageFile || originalImageFile === imageFile) return;
        loadFile(originalImageFile, { preserveOriginal: true });
      });
      cropCancelBtn.addEventListener('click', closeCropModal);
      cropResetBtn.addEventListener('click', resetCropSelection);
      cropModal.addEventListener('click', (event) => {
        if (event.target === cropModal) closeCropModal();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && cropModal.classList.contains('show')) closeCropModal();
      });

      cropImage.addEventListener('pointerdown', (event) => {
        const point = eventToImagePoint(event);
        cropPointerId = event.pointerId;
        cropStartPoint = point;
        cropImage.setPointerCapture(cropPointerId);
        cropRect = { x: point.x, y: point.y, width: 0, height: 0 };
        renderCropSelection();
      });

      cropImage.addEventListener('pointermove', (event) => {
        if (cropStartPoint === null) return;
        const point = eventToImagePoint(event);
        cropRect = {
          x: Math.min(cropStartPoint.x, point.x),
          y: Math.min(cropStartPoint.y, point.y),
          width: Math.abs(point.x - cropStartPoint.x),
          height: Math.abs(point.y - cropStartPoint.y),
        };
        renderCropSelection();
      });

      function finishCropSelection() {
        cropStartPoint = null;
        if (cropPointerId !== null) {
          cropImage.releasePointerCapture(cropPointerId);
          cropPointerId = null;
        }
      }

      cropImage.addEventListener('pointerup', finishCropSelection);
      cropImage.addEventListener('pointercancel', finishCropSelection);

      cropApplyBtn.addEventListener('click', async () => {
        if (!imageFile || !cropRect || cropRect.width < 8 || cropRect.height < 8) return;

        cropApplyBtn.disabled = true;
        cropApplyBtn.textContent = '切り抜き中...';

        try {
          const bitmapUrl = URL.createObjectURL(imageFile);
          const sourceImage = new Image();
          await new Promise((resolve, reject) => {
            sourceImage.onload = resolve;
            sourceImage.onerror = reject;
            sourceImage.src = bitmapUrl;
          });

          const scaleX = sourceImage.naturalWidth / cropImage.clientWidth;
          const scaleY = sourceImage.naturalHeight / cropImage.clientHeight;
          const sx = Math.round(cropRect.x * scaleX);
          const sy = Math.round(cropRect.y * scaleY);
          const sw = Math.max(1, Math.round(cropRect.width * scaleX));
          const sh = Math.max(1, Math.round(cropRect.height * scaleY));

          const canvas = document.createElement('canvas');
          canvas.width = sw;
          canvas.height = sh;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(sourceImage, sx, sy, sw, sh, 0, 0, sw, sh);

          const blob = await new Promise((resolve) => canvas.toBlob(resolve, 'image/jpeg', 0.95));
          URL.revokeObjectURL(bitmapUrl);
          if (!blob) throw new Error('切り抜き画像の生成に失敗しました');

          const croppedName = imageFile.name.replace(/\.[^.]+$/, '') || 'cropped';
          loadFile(new File([blob], `${croppedName}-cropped.jpg`, { type: 'image/jpeg' }), { preserveOriginal: true });
          closeCropModal();
          setStatus('トリミング画像を適用しました', 'success');
        } catch (error) {
          setStatus('トリミングに失敗しました: ' + error.message, 'error');
        } finally {
          cropApplyBtn.textContent = 'この範囲で切り抜く';
          cropApplyBtn.disabled = !cropRect || cropRect.width < 8 || cropRect.height < 8;
        }
      });

      // Status helper
      function setStatus(msg, type) {
        statusBar.innerHTML = msg;
        statusBar.className = 'status-bar' + (type ? ' ' + type : '');
      }

      // TODO format: convert checkbox symbols → Markdown task list, others → unchecked
      function toTodoLine(line) {
        // checked: ✓ ✔ ☑ ● [x] [X] [v] [V]
        if (/^[✓✔☑●]\s*/.test(line) || /^\[[xXvV✓]\]\s*/.test(line)) {
          return '- [x] ' + line.replace(/^[✓✔☑●]\s*/, '').replace(/^\[[xXvV✓]\]\s*/, '');
        }
        // unchecked: □ ☐ ○ [ ] already
        if (/^[□☐○]\s*/.test(line) || /^\[\s*\]\s*/.test(line)) {
          return '- [ ] ' + line.replace(/^[□☐○]\s*/, '').replace(/^\[\s*\]\s*/, '');
        }
        // その他の行もすべて未チェックのTODOとして扱う
        return '- [ ] ' + line;
      }

      // Format converter (raw OCR text → selected format)
      function convertFormat(raw, fmt) {
        const lines = raw.split('\n').map(l => l.trim()).filter(l => l.length > 0);
        switch (fmt) {
          case 'plain':
            return lines.join('\n');
          case 'bullet':
            return lines.map(l => `・${l}`).join('\n');
          case 'markdown':
            return lines.join('\n\n');
          case 'todo':
            return lines.map(toTodoLine).join('\n');
          case 'csv':
            return lines.map(l => `"${l.replace(/"/g, '""')}"`).join('\n');
          case 'tsv':
            return lines.map(l => l.replace(/\t/g, ' ')).join('\t\n');
          default:
            return raw;
        }
      }

      // Compress image to under 1MB via Canvas
      async function compressImage(file, maxBytes = 900 * 1024) {
        return new Promise((resolve) => {
          const img = new Image();
          const url = URL.createObjectURL(file);
          img.onload = () => {
            URL.revokeObjectURL(url);
            const canvas = document.createElement('canvas');
            let { width, height } = img;
            // Scale down if too large
            const MAX_DIM = 2048;
            if (width > MAX_DIM || height > MAX_DIM) {
              const scale = Math.min(MAX_DIM / width, MAX_DIM / height);
              width = Math.round(width * scale);
              height = Math.round(height * scale);
            }
            canvas.width = width;
            canvas.height = height;
            canvas.getContext('2d').drawImage(img, 0, 0, width, height);
            // Try reducing quality until under maxBytes
            let quality = 0.9;
            const tryBlob = () => {
              canvas.toBlob((blob) => {
                if (blob.size <= maxBytes || quality <= 0.3) {
                  resolve(new File([blob], 'compressed.jpg', { type: 'image/jpeg' }));
                } else {
                  quality -= 0.1;
                  tryBlob();
                }
              }, 'image/jpeg', quality);
            };
            tryBlob();
          };
          img.src = url;
        });
      }

      // Extract with OCR.space
      extractBtn.addEventListener('click', async () => {
        if (!imageFile) { setStatus('画像を選択してください', 'error'); return; }

        extractBtn.disabled = true;
        progressWrap.classList.add('show');
        progressBar.style.width = '20%';
        setStatus('<span class="spinner"></span>画像を最適化中...', 'loading');

        try {
          const compressed = await compressImage(imageFile);
          progressBar.style.width = '40%';
          setStatus('<span class="spinner"></span>OCR.space で解析中...', 'loading');

          const formData = new FormData();
          const apiKey = ocrApiKeyEl.value.trim() || OCR_SPACE_DEMO_KEY;
          formData.append('apikey', apiKey);
          formData.append('file', compressed);
          formData.append('language', 'jpn');
          formData.append('isOverlayRequired', 'false');
          formData.append('isTable', isTableEl.checked ? 'true' : 'false');
          formData.append('detectOrientation', 'true');
          formData.append('scale', 'true');
          formData.append('OCREngine', '2');

          progressBar.style.width = '60%';
          const resp = await fetch('https://api.ocr.space/parse/image', {
            method: 'POST',
            body: formData,
          });

          if (!resp.ok) throw new Error(`HTTP ${resp.status}`);

          const data = await resp.json();
          if (data.IsErroredOnProcessing) {
            throw new Error(data.ErrorMessage?.[0] || 'OCR処理エラー');
          }

          rawOcrText = data.ParsedResults?.[0]?.ParsedText || '';
          const converted = convertFormat(rawOcrText, selectedFormat);

          emptyState.style.display = 'none';
          outputBox.style.display = 'block';
          outputBox.value = converted;
          progressBar.style.width = '100%';
          setStatus(`✓ 抽出完了（${converted.length}文字）`, 'success');
        } catch (e) {
          setStatus('エラー: ' + e.message, 'error');
          progressWrap.classList.remove('show');
        } finally {
          extractBtn.disabled = false;
        }
      });

      // Copy
      copyBtn.addEventListener('click', async () => {
        const text = outputBox.value;
        if (!text) return;
        await navigator.clipboard.writeText(text);
        copyBtn.textContent = '✓ コピーしました';
        copyBtn.classList.add('copied');
        setTimeout(() => {
          copyBtn.innerHTML = '📋 コピー';
          copyBtn.classList.remove('copied');
        }, 2000);
      });

      // Download
      downloadBtn.addEventListener('click', () => {
        const text = outputBox.value;
        if (!text) return;
        const exts = { markdown: 'md', todo: 'md', csv: 'csv', tsv: 'tsv', plain: 'txt', bullet: 'txt' };
        const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `snaptext.${exts[selectedFormat] || 'txt'}`;
        a.click();
        URL.revokeObjectURL(url);
      });
    })();
  </script>
</BaseLayout>
