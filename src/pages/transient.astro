---
import BaseLayout from '../layouts/BaseLayout.astro';
import TransientNotes from '../components/transient/TransientNotes.tsx';
---

<BaseLayout title="Transient" description="Transient Notes: 一時的 / 非蓄積 / 自動消去のノート">
  <div class="container mx-auto max-w-7xl px-4 py-10">
    <div class="mb-10">
      <p class="text-sm font-semibold uppercase tracking-[0.35em] text-cyan-300/70">Transient</p>
      <h1 class="mt-3 text-4xl font-bold text-white md:text-5xl">Transient Notes</h1>
      <p class="mt-4 max-w-3xl text-base leading-8 text-gray-400">
        「思い出すためだけに使うメモ」をテーマにした、一日限定のノートページです。テンプレートは永続化し、当日ノートは Daily
        Expiry で自動的に消えます。
      </p>
    </div>

    <TransientNotes client:load />
  </div>
</BaseLayout>
