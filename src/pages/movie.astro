---
import BaseLayout from '../layouts/BaseLayout.astro';
import MovieTrimmer from '../components/movie/MovieTrimmer.tsx';
import MovToMp4Converter from '../components/movie/MovToMp4Converter.tsx';
---

<BaseLayout title="Movie Tool" description="動画トリミングツール（ブラウザ内処理）">
  <script is:inline src="/coi-serviceworker.js"></script>
  <div class="container mx-auto px-4 py-8 max-w-4xl">
    <h1 class="text-3xl font-bold text-white mb-2">Movie Tool</h1>
    <p class="text-gray-400 mb-8">動画トリミングツール — ブラウザ内で処理（サーバー不要）</p>
    <MovieTrimmer client:load />
    <div class="mt-6">
      <MovToMp4Converter client:load />
    </div>
    <p class="mt-6 text-xs text-gray-600">
      処理はすべてブラウザ内で行われます。ファイルはサーバーに送信されません。<br />
      初回ロード時に ffmpeg.wasm（約30MB）をダウンロードします。
    </p>
  </div>
</BaseLayout>
