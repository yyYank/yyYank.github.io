    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@tailwindcss/typography": "^0.5.10",
    "astro": "^6.0.5",
    "framer-motion": "^12.34.0",
    "fuse.js": "^7.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "tailwindcss": "^3.4.0"
